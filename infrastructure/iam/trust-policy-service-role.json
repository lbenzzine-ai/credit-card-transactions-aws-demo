{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowServiceAccountToAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::__AWS_ACCOUNT_ID__:user/svc-card-txn-demo"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "card-txn-demo-external-id"
        }
      }
    }
  ]
}
