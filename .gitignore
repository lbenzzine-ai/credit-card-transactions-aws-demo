# Live AWS resource identifiers + service-account credentials — never commit these
infrastructure/.env
infrastructure/iam/rendered/

# Generated by setup.sh with real bucket/table/queue/topic names — regenerate locally instead
src/main/resources/application.properties

# Kafka Streams local state (RocksDB), regenerated on each demo run
kafka-streams-state/

# Maven build output
target/

# OS/editor cruft
.DS_Store
*.iml
.idea/
.vscode/
